// rule done {
//     when {
//         b: Boolean b === true from true;
//     }
//     then {
//         if (checkSAI({selection: "done", action: "ButtonPressed", input: "don't_care"})) {
//             halt();
//         } else {
//             backtrack();
//         }
//     }
// }
// function for adding additional logging
rule gradeAllOnDoneVariableCount {
  when {
    sai: StudentValues sai.selection == "done";

    p: Problem { pairsByLeft: byLeft, oneColumn: oc, leftAnswerList: la };

    l1: TextInput l1.name == "l1" { value: vL1 };
    r1: TextInput r1.name == "r1" { value: vR1 };

    l2: TextInput l2.name == "l2" { value: vL2 };
    r2: TextInput r2.name == "r2" { value: vR2 };

    l3: TextInput l3.name == "l3" { value: vL3 };
    r3: TextInput r3.name == "r3" { value: vR3 };

    l4: TextInput l4.name == "l4" { value: vL4 };
    r4: TextInput r4.name == "r4" { value: vR4 };
  }
  then {
    // console.log("ByLeft", byLeft);
    const expectedCount = la.length; // number of correct pairs in this item
    const usedLeft  = {};
    const usedRight = {};

    let ok = true;
    let correctCount = 0;

    function processRow(vL, vR) {
      // console.log("Checking: ", vL, vR);
      if (!ok) return;                 // short-circuit after a failure
      const leftFilled  = !!vL;
      const rightFilled = !!vR;

      if (!leftFilled && (oc || !rightFilled)) {
        return; // empty row -> ignore
      }
      // console.log("MADE IT PAST FIRST CHECK");
      if (!leftFilled || (!rightFilled && !oc)) {
        ok = false; // incomplete pair
        return;
      }
      // console.log("MADE IT PAST Second CHECK");
      if (!oc && byLeft[vL] === undefined) {
        ok = false; // left not in canonical set
        return;
      }
      // console.log("MADE IT PAST Third CHECK");
      if (!oc && byLeft[vL] !== vR) {
        ok = false; // wrong mapping
        return;
      }
      // console.log("MADE IT PAST Fourth CHECK");
      if (usedLeft[vL] || usedRight[vR]) {
        ok = false; // duplicate use
        return;
      }
      // console.log("WE MADE IT");
      usedLeft[vL]  = true;
      if (vR){
        usedRight[vR] = true;
      }
      correctCount++;
    }

    // Check up to 4 rows
    // console.log("Expected Count: ", expectedCount);
    processRow(vL1, vR1);
    // console.log("Correct Count 1: ", correctCount);
    processRow(vL2, vR2);
    // console.log("Correct Count 2: ", correctCount);
    processRow(vL3, vR3);
    // console.log("Correct Count 3: ", correctCount);
    processRow(vL4, vR4);
    // console.log("Correct Count 4: ", correctCount);

    // Must have exactly the expected number of correct pairs
    // console.log("Ok before check: ", ok, "Correct count: ", correctCount, "expected count: ", expectedCount);
    if (ok && correctCount !== expectedCount) {
      ok = false;
    }
    var loggingLibrary = CTATCommShell.commShell.getLoggingLibrary();
    loggingLibrary.logInterfaceAttempt("all_ok", "",ok);
    console.log("All: ", ok);
    if (checkSAI({ selection: "done", action: "ButtonPressed", input: "don't_care" })) {
      halt();
    } else {
      backtrack();
    }
    
  }
}
