    elem.setAttribute("style", "white-space: pre-wrap; background-color: black; border-style: inset; border-color: black; background-image: radial-gradient( rgba(0, 60, 0, 0.75), black 100% ); margin: 0; padding: 2rem; color: white; font: 1.3rem Inconsolata, monospace; text-shadow: 0 0 1px #C8C8C8;"  );  
