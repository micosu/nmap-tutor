import("productionRules-final.nools");
import("SkillDefinitions.nools");

global probType = "Identify Services";
global fixLeft = true;
global oneColumn = false;
global probtxt = "The services section of our networks should contain a file server providing SMB file sharing over TCP port 445, and a print server providing printing services (LPD on TCP port 515 and JetDirect on TCP port 9100). All other services are prohibited on this network segment. Using nmap, identify which server is configured at which IP address. <br><strong>Scan only the services portion the office network and DMZ with one nmap command.</strong>";
global title = "Tutor: NMAP problem 3";
global opQuestion = "Based on the output, which server is which service?";
global leftTitle = "Server";
global rightTitle = "IP Address";
global imgAddress = "Assets/IdentifyServices_2.png";

global sudoAnswer = ["sudo"];
global nmapAnswer = ["nmap"];
global scanAnswer = ["-sS", "-sT", ""];
global pFlagAnswer = ["-p", "-pT"];
global outputAnswer = ["-oN", ""];
global pingAnswer = ["-Pn", ""];
global portsAnswer = ["-p 445,515,9100"];
global ipAnswer = ["10.0.0.0/27 11.0.0.0/27"];

global leftAnswer = ["File Server", "Print Server"];
global rightAnswer = ["11.0.0.21", "10.0.0.21"];

