		if (checkSAI({selection: sel, action: "UpdateTextField", input: -1}, 
						function() {
                return (l.includes(i));
            
                
						})) {
			modify(ie, "value", i);
      temp = [...l];
      let index = l.indexOf(i);
      if (index !== -1) { 
          temp.splice(index, 1); 
      }
      modify(p, "leftAnswerList", temp);
      // console.log(leftAnswer);
      // temp = [...r];
      // if (index !== -1) { 
      //     temp.splice(index, 1); 
      // }
      // modify(p, "rightAnswerList", temp);

      temp = p.leftEntered;
      temp.push(i); 
      modify(p, "leftEntered", temp);

      
   
			halt();
		}
		else {
			backtrack();
		}
	}
}

// This rule is for when you enter something on the left side, but there is already input in the matching right side box. 
rule enterLeftSec {
	when {
    ie: TextInput !ie.value { name: sel };

    p: Problem (p.firstAttemptCorrect == 1 || p.secondAttemptCorrect == 1) && p.leftColumn.includes(sel){leftAnswerList: l};

    ro: row ro.left == sel {right: sel2};
    
    ie2: TextInput ie2.name == sel2 && ie2.value {value: v};

    pr: pair pr.right == v {left: ans};
    
    sai: StudentValues sai.selection == sel {input: i};
	}
	then {    
    isControl = CTATConfiguration.get("study_condition_name1") == "control";
    if (!isControl) {
      assert(new Skill("resultAnalysis", "nmapScanning"));
    }
		if (checkSAI({selection: sel, action: "UpdateTextField", input: -1}, 
						function() {
                return (i.includes(ans));
         
						})) {
			modify(ie, "value", i);

      temp = p.leftEntered;
      temp.push(i); 
      modify(p, "leftEntered", temp);
      
			halt();
		}
		else {
			backtrack();
		}
	}
}

// This rule is for when you enter something in the right side, and there is nothing on the matching slot on the left. 
rule enterRight {
	when {
    ie: TextInput !ie.value { name: sel };
    
		p: Problem  (p.firstAttemptCorrect == 1 || p.secondAttemptCorrect == 1) && p.rightColumn.includes(sel) && (p.leftEntered.length != leftAnswer.length || p.rightEntered.length != rightAnswer.length){rightAnswerList: r, leftAnswerList:l};

    ro: row ro.right == sel {left: sel2};
    
    ie2: TextInput ie2.name == sel2 && !ie2.value {name: sel2};
    
    sai: StudentValues sai.selection == sel {input: i};
	}
	then {
    isControl = CTATConfiguration.get("study_condition_name1") == "control";
    console.log("is  ----- ", isControl);
    let bottomOutHint = "";
    if (!isControl) {
      if (probType == "Bad Ports") {
        assert(new Hint("Try to identify the IP address first, then look up that IP address in the network map."));      
        // assert(new Hint("The machine(s) you're looking for are number(s): " + rightAnswer));
        bottomOutHint = "The machine(s) you're looking for are number(s): " + rightAnswer;
      } else if (probType == "Identify Services" ) {
        assert(new Hint("If a machine has ports open that indicates it is providing a service on those ports."));  
        assert(new Hint("For each machine you're trying to identify, look at the scan results and compare the open ports to those given in the problem statement."));           
  
        let ansHint = "";      
        let arrayLength = rightAnswer.length;
        for (var i = 0; i < arrayLength; i++) { 
            ansHint = ansHint + leftAnswer[i] + ":" +  rightAnswer[i] + " ";         
        }            
        // assert(new Hint("The machine(s) you're looking for are " + ansHint));
        bottomOutHint = "The machine(s) you're looking for are " + ansHint
      }
      else if (probType == "Rogue Workstations" ) {
        let x = 0; // Pass - no right column in ping scan questions. 
      }
      else if (probType == "Unresponsive Workations") {
        let x = 0; // Pass - no right column in ping scan questions.
      }
      assert(new Skill("resultAnalysis", "nmapScanning"));
    } else {
      assert(new Hint("Click next to reveal answer"));
    }
    assert(new Hint(bottomOutHint));
    
    if (checkSAI({selection: sel, action: "UpdateTextField", input: -1}, 
						function() {
                  for (var j = 0; j < r.length; j++) {
              			if(i.includes(r[j])){
                      return true;
                    };
              		}
    							return (false);
						})) {
			modify(ie, "value", i);
      temp = [...r];
      let index = r.indexOf(i);
      if (index !== -1) { 
          temp.splice(index, 1); 
      }
      modify(p, "rightAnswerList", temp);

      temp = [...l];
      if (index !== -1) { 
          temp.splice(index, 1); 
      }
      modify(p, "leftAnswerList", temp);

      temp = p.rightEntered;
      temp.push(i); 
      modify(p, "rightEntered", temp);
      
        
			halt();
		}
		else {
			backtrack();
		}
	}
}

