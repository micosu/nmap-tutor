rule done {
    when {
        p : Problem p.leftEntered.length === leftAnswer.length && p.rightEntered.length === rightAnswer.length {leftColumn:l};
    }
    then {
        assert(new Hint("You've completed all the steps. Well done!"));
        assert(new Hint("Click the 'Done' button to finish."));

        if (checkSAI({selection: "done", action: "ButtonPressed", input: "don't_care"})) {
            halt();
        } else {
            backtrack();
        }
    }
}