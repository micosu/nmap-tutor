    assert(new Skill("scanType", "nmapScanning"));
    
    if (scanAnswer.includes('-sS')){
      ans = 'Port Scan';
      assert(new Hint("Your task requires looking at specific ports, what type of scan would check specific ports?"));    
    }
    else{
      ans = 'Ping Scan';
      assert(new Hint("This task does not require looking at specific ports, what type of scan would skip scanning ports on each machine?"));    
    }

    
    assert(new Hint("Select ''" + ans + "'' in the drop down menu." ));    
    
