rule enterSecondCommand {
  
	when {
		p: Problem p.firstAttemptCorrect == -1 {secondAttemptCorrect: s};

		ie: TextInput ie.name == 'commandInput2' && !ie.value { name: sel };

    sai: StudentValues sai.selection == sel {input: ipt};
	}
	then {
    assert(new Hint("The questions above should help you compose the correct command."));
    assert(new Hint("Enter each of the above text fields, in order."));
    assert(new Hint("Enter '" + sudoAnswer[0] + " " + nmapAnswer[0] + " " + scanAnswer[0] + " " + portsAnswer[0] + " " + ipAnswer[0] + "' in the box."));

    // Since this is the SECOND try. Give them single credit on all skills associated with the command, no duplicate call to asssert skills later in the rule
    // Because theoretically they have filled in the previous sections by now and already gotten 
    // credit once.       
    assert(new Skill("sudo", "nmapScanning"));      
    assert(new Skill("nmapCommand", "nmapScanning"));      
    assert(new Skill("scanType", "nmapScanning"));
    assert(new Skill("scanTypeFlag", "nmapScanning"));
    assert(new Skill("portSpecification", "nmapScanning"));
    assert(new Skill("rangeSpecification", "nmapScanning"));
    
		if (checkSAI({selection: sel, action: "UpdateTextField", input: -1}, 
						function() {
								  const answers = [scanAnswer, outputAnswer, pingAnswer];

                  let s = ipt.trim();
                  let flag = true;

                  let templist = ListIPAddresses("nmap " + ipAnswer[0]).sort();
                  let fullist = ListIPAddresses(s).sort();

                  if (templist[0] != fullist[0]) { return false };
                  if (templist[templist.length -1] != fullist[fullist.length -1]) { return false };
                  if (templist.length != fullist.length) { return false };
                 
                  //console.log("This Sould run");
                  // Since we will be iteratively checking the last element in the input command, we need to check if it matches any of the formats. This regex should match all cases. It is anchored only at the END of the string, and will ignore the beginning - so you can pass in the entire nmap command, and it will ignore everything but the addresses.
                  // NOTE! You'll want to make sure you're stripping any trailing whitespace characters (like a newline) from the command, if your tutor captures that input from the student hitting enter on the command. 
                  var testAnyMatch = new RegExp(/(?:(?:25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9][0-9]|[0-9])\.){3}(?:25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9][0-9]|[0-9])\-(?:(?:25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9][0-9]|[0-9])\.){3}(?:25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9][0-9]|[0-9])$|(?:(?:25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9][0-9]|[0-9])\.){3}(?:25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9][0-9]|[0-9])(\/([4-9]|(3[0-2]?)|(2[0-9]?)|(1[0-9]?)))?$|(?:(?:25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9][0-9]|[0-9])(\-(?:25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9][0-9]|[0-9]))?\.){3}(?:25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9][0-9]|[0-9])(\-(?:25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9][0-9]|[0-9]))?$/); 
                  let allAddresses = s.match(testAnyMatch);  
                  //console.log("All Address struct");
                  //console.log(allAddresses);
                  //console.log("s = " + s);
                  // If the 'anything matched' regex returns a result, that means the last element still in the buffer that needs to be processed. Once all the address specifications are done, the last element will be part of the nmap command, such as flags or port specifications, and won't match. 
                  while (allAddresses != null)
                  {
                    // Now that we've dealt with that input, we should remove it and try to parse the command line again in case there were multiple groups of addresses provided.   	
                    // Note that we need to trim the whitespace again! 
                    s = s.replace(allAddresses[0], "").trim();
                    //console.log("+s = " + s);
                    // Try to parse the command again to see if there are more address groups to cover. This will be tested back at the top of the loop. 
                    allAddresses = s.match(testAnyMatch);
                  }
                  //console.log("sEND = " + s);
                  let slist = s.split(' ');

                  // checking if the first item is sudo and if so, removing it. 
                  if (sudoAnswer.includes(slist[0])) {
                      slist.shift(); // Remove the first element
                  } else {
                      return false;
                  }

                  // Checking if the (now) first item is the nmap command and if so removing it. 
                  if (nmapAnswer.includes(slist[0])) {
                      slist.shift(); // Remove the next element
                  } else {
                      return false;
                  }
                
                  
             
                  for (let i of answers) {
                      let flag = true;                      
                      for (let j of i) {
                          if (slist.includes(j)) {
                              slist.splice(slist.indexOf(j), 1); // Remove the matched element
                              flag = false;
                              break;
                          }
                      }
                      if (flag && !i.includes('')) {
                          return false;
                      }                      
                  }

                  // Checking for the correct port specification and if so, removing it.
                  let portoffset = slist.indexOf("-p");
                  let portSpecification;
                  if (portoffset == -1 ) 
                  { 
                    portoffset = slist.indexOf("-pT"); 
                  }              
                  if ( portoffset != -1 )
                  {
                    portSpecification = slist[portoffset] + " " + slist[portoffset + 1];
                  }
                  if (portSpecification != null){
                    templist = checkPorts(portSpecification);  
                    fullist = checkPorts(portsAnswer[0]); 
  
                    if (templist[0] != fullist[0]) { return false };
                    if (templist[templist.length -1] != fullist[fullist.length -1]) { return false };
                    if (templist.length != fullist.length) { return false };
                    
                    slist.shift(); // The port list is acceptable, remove the -p or -pT item. 
                    slist.shift(); // The port list is acceptable, remove the list of ports. 
                  }
               
                  return slist.length === 0;
						})){
			modify(ie, "value",1);
      modify(p, "secondAttemptCorrect", 1);
            
      
      
      revealResults();

      if (p.fixLeft){
            // temp = p.leftEntered;
            for (var i = 0; i < leftAnswer.length; i++) {
              const container = document.getElementById("l" + (i+1));
              const input = container.querySelector("input");
              
              if (input) {
                input.value = leftAnswer[i];  // already set in your case
              
                // Dispatch an "input" event so CTAT sees the change
                input.dispatchEvent(new Event("input", { bubbles: true }));
              
                // Optional: fire "change" if CTAT expects commit-on-blur
                input.dispatchEvent(new Event("change", { bubbles: true }));
                input.dispatchEvent(new KeyboardEvent("keydown", { key: "Enter", bubbles: true }));

                console.log("Simulated student entry.");
              }
              
        		}
            modify(p, "rightAnswerList", []);
        
      }
      
      if (p.oneColumn){
        let element6 = document.getElementById("workstation");
        element6.style.display = "none";

      }
      
      assert(new TPA("sudoInput", "lock"));
      assert(new TPA("portInput", "lock"));
      assert(new TPA("nmapInput", "lock"));
      assert(new TPA("scanTypeInput", "lock"));
      assert(new TPA("outputTypeInput", "lock"));
      assert(new TPA("pingScanInput", "lock"));
      assert(new TPA("ipInput", "lock"));

      scanResultSaver = createPortScanResults(exampledata, ipt);
      document.getElementById("largerScanText").innerHTML += "<br>" + scanResultSaver;
      assert(new TPA("output",  "UpdateTextArea", scanResultSaver));

      assert(new StudentValues("l1", "", "")); 
      halt();
		}
		else {
      backtrack();
		}
	}
}

// If you are entering an answer on the left hand side first (there is no matching value in the right hand side) this rule fires. 
rule enterLeft {
	when {
    ie: TextInput !ie.value { name: sel };

		p: Problem p.oneColumn == false && (p.firstAttemptCorrect == 1 || p.secondAttemptCorrect == 1) && p.leftColumn.includes(sel)&& (p.leftEntered.length != leftAnswer.length || p.rightEntered.length != rightAnswer.length){leftAnswerList: l, rightAnswerList:r, fixLeft: left_fixed};

    ro: row ro.left == sel {right: sel2};
    
    ie2: TextInput ie2.name == sel2 && !ie2.value {name: sel2};
    
    sai: StudentValues sai.selection == sel {input: i};
	}
	then {
    isControl = CTATConfiguration.get("study_condition_name1") == "control";
    console.log("is ----- ", isControl);
    if (!isControl) {
      if (probType == "Bad Ports") {
        assert(new Hint("Look at the results of the scan and compare them to the ports you were looking for. "));
        assert(new Hint("Which IP addresses in the scan have the targeted ports open?"));  
      } 
      else if (probType == "Rogue Workstations" ) {
        assert(new Hint("Compare the network map to the scan results. What doesn't match up?"));  
        assert(new Hint("Look at the scan results and compare them to the network map, are there machines that are not on the network map which appear in the scan results?"));  
      }
      else if (probType == "Unresponsive Workations") {
        assert(new Hint("Compare the network map to the scan results. What doesn't match up?"));  
        assert(new Hint("Look at the network map and compare it to the scan results, are there machines that are on the network map which don't appear in the scan results?"));     
      }
    } else {
      assert(new Hint("Click next to reveal answer"));
    }
    assert(new Hint("The machine(s) you're looking for are at: " + leftAnswer));

    if (!left_fixed && !isControl){
      assert(new Skill("resultAnalysis", "nmapScanning"));
    }
    
		if (checkSAI({selection: sel, action: "UpdateTextField", input: -1}, 
						function() {
                return (l.includes(i));
            
                
						})) {
			modify(ie, "value", i);
      temp = [...l];
      let index = l.indexOf(i);
      if (index !== -1) { 
          temp.splice(index, 1); 
      }
      modify(p, "leftAnswerList", temp);
      temp = [...r];
      if (index !== -1) { 
          temp.splice(index, 1); 
      }
      modify(p, "rightAnswerList", temp);

      temp = p.leftEntered;
      temp.push(i); 
      modify(p, "leftEntered", temp);
      assert(new StudentValues(sel2, "", ""));
			halt();
		}
		else {
			backtrack();
		}
	}
}


// This is for problem type 3, specifically, because there only is 1 column. This rule covers that case to allow completion. 
