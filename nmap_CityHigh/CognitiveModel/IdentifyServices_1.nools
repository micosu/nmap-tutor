global probType = "Identify Services";
global fixLeft = true;
global oneColumn = false;
global probtxt = "The services section of our DMZ network should contain a web server hosting both secure and insecure web connections (HTTP on TCP port 80 and HTTPS on TCP port 443), a DNS server providing lookup services over TCP port 53, and a mail server providing SMTP over TCP ports 25, 465, 587 and 2525. All other services are prohibited on this network segment. Using nmap, identify which server is configured at which IP address.  <br><strong>Scan only the services portion of the DMZ network.</strong>";
global title = "Tutor: NMAP problem 5";
global opQuestion = "Based on the output, which server is which service?";
global leftTitle = "Server";
global rightTitle = "IP Address";
global imgAddress = "Assets/IdentifyServices_1.png";

global sudoAnswer = ["sudo"];
global nmapAnswer = ["nmap"];
global scanAnswer = ["-sS", "-sT", ""];
global pFlagAnswer = ["-p", "-pT"];
global outputAnswer = ["-oN", ""];
global pingAnswer = ["-Pn", ""];
global portsAnswer = ["-p 80,443,53,25,465,587,2525"];
global ipAnswer = ["10.132.0.0/27"];

global leftAnswer = ["Web Server", "DNS Server", "Mail Server"];
global rightAnswer = ["10.132.0.22", "10.132.0.21", "10.132.0.20"];

